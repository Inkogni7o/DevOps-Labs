APP_NAME=Store Lab API
APP_VERSION=0.1.0
ENVIRONMENT=local
DATABASE_URL=postgresql+asyncpg://store_lab:store_lab_password@postgres:5432/store_lab
REDIS_URL=redis://redis:6379/0
JWT_SECRET=local-development-jwt-secret-change-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
S3_ENDPOINT=http://minio:9000
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000","http://127.0.0.1:3001"]
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin-password-change-me
SEED_ADMIN_FULL_NAME=Store Admin
